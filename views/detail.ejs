<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= ticket.eventName %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">
    <main class="container py-4">
        <div class="col-md-8 mx-auto">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4"><a href="/" class="btn btn-sm btn-outline-secondary mb-3">← Quay lai</a>
                    <h1 class="h3">
                        <%= ticket.eventName %>
                    </h1>
                    <p class="text-muted mb-3"><small>Ma ve: <strong>
                                <%= ticket.ticketId %>
                            </strong></small></p>
                    <% if (ticket.imageUrl) { %><img src="<%= ticket.imageUrl %>" alt="<%= ticket.eventName %>"
                            class="img-fluid rounded mb-3" style="max-height: 400px; object-fit: cover; width: 100%;">
                        <% } %>
                            <div class="row g-2 mb-3">
                                <div class=\"col-md-4\">
                                    <div class="card">
                                        <div class="card-body py-2"><small class="text-muted">Gia ve</small>
                                            <h5>
                                                <%= new Intl.NumberFormat('vi-VN', { style: 'currency' , currency: 'VND'
                                                    }).format(ticket.price || 0) %>
                                            </h5>
                                        </div>
                                    </div>
                                </div>
                                <div class=\"col-md-4\">
                                    <div class=\"card\">
                                        <div class=\"card-body py-2\"><small class=\"text-muted\">So luong</small>
                                            <h5>
                                                <%= ticket.quantity %> ve
                                            </h5>
                                        </div>
                                    </div>
                                </div>
                                <div class=\"col-md-4\">
                                    <div class=\"card\">
                                        <div class=\"card-body py-2\"><small class=\"text-muted\">Loai ve</small>
                                            <h5>
                                                <span class=\"badge text-bg-info\"><%= ticket.typeTicket || ticket.type || '-' %></span>
                                            </h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% const getStatus=(q)=> q <= 0 ? 'Het ve' : q <=10 ? 'Sap het' : 'Con ve' ; const
                                    statusClass=ticket.quantity <=0 ? 'danger' : ticket.quantity <=10 ? 'warning'
                                    : 'success' ; %><span class="badge text-bg-<%= statusClass %> mb-3">
                                        <%= getStatus(ticket.quantity) %>
                                    </span>
                                    <div class="border-top pt-3 mb-3">
                                        <% if (ticket.createdAt) { %><small class="text-muted">Ngay them: <%= new
                                                    Date(ticket.createdAt).toLocaleString('vi-VN') %></small><br>
                                            <% } %>
                                                <% if (ticket.updatedAt) { %><small class="text-muted">Cap nhat: <%= new
                                                            Date(ticket.updatedAt).toLocaleString('vi-VN') %></small>
                                                    <% } %>
                                    </div>
                                    <div class="d-flex gap-2"><a href="/tickets/<%= ticket.ticketId %>/edit"
                                            class="btn btn-primary flex-grow-1">✏️ Sua</a>
                                        <button type="button" class="btn btn-danger flex-grow-1" data-bs-toggle="modal" data-bs-target="#deleteModal" data-ticketid="<%= ticket.ticketId %>">🗑️ Xoa</button>
                                    </div>
                </div>
            </div>
    </main>
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Xóa vé</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Bạn chắc chắn muốn xóa vé này? Hành động này không thể khôi phục.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Xóa</button>
                </div>
            </div>
        </div>
    </div>
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="successToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true" data-message="<%= typeof message !== 'undefined' ? message : '' %>">
            <div class="toast-header bg-success text-white">
                <strong class="me-auto">✓ Thông báo</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body" id="toastMessage"></div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const toastElement = document.getElementById('successToast')
            const message = toastElement.dataset.message
            if (message) {
                document.getElementById('toastMessage').textContent = message
                const toast = new bootstrap.Toast(toastElement)
                toast.show()
            }
            
            let ticketIdToDelete = null
            const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'))
            document.querySelectorAll('[data-bs-target="#deleteModal"]').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    ticketIdToDelete = e.target.dataset.ticketid
                    deleteModal.show()
                })
            })
            document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
                if (ticketIdToDelete) {
                    const form = document.createElement('form')
                    form.method = 'POST'
                    form.action = `/tickets/${ticketIdToDelete}/delete`
                    document.body.appendChild(form)
                    form.submit()
                }
            })
        })
    </script>
</body>

</html>