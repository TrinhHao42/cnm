<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quan ly</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">
    <main class="container py-4">
        <header class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
            <h1 class="h3 mb-0">Quan ly</h1>
            <a class="btn btn-primary" href="/tickets/new">+ Them ve</a>
        </header>

        <section class="card border-0 shadow-sm">
            <div class="card-body">
            <form class="row g-2 mb-3" method="GET" action="/">
                <div class="col-12 col-md-6">
                    <input class="form-control" type="text" name="keyword" placeholder="Tim theo ten su kien..." value="<%= keyword || '' %>">
                </div>
                <div class="col-auto">
                    <button class="btn btn-outline-primary" type="submit">Tim kiem</button>
                </div>
                <div class="col-auto">
                    <a class="btn btn-outline-secondary" href="/">Xoa loc</a>
                </div>
            </form>

            <% if (message) { %>
                <div class="alert alert-info py-2"><%= message %></div>
            <% } %>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Event</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th>State</th>
                            <th>Image</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!tickets || tickets.length === 0) { %>
                            <tr>
                                <td colspan="7" class="text-center text-muted">Khong co du lieu</td>
                            </tr>
                        <% } %>

                        <% (tickets || []).forEach((ticket) => { %>
                            <tr>
                                <td><%= ticket.ticketId %></td>
                                <td><%= ticket.eventName %></td>
                                <td><%= Number(ticket.price).toLocaleString('vi-VN') %> VND</td>
                                <td><%= ticket.quantity %></td>
                                <td>
                                    <span class="badge <%= ticket.status === 'Het ve' ? 'text-bg-danger' : (ticket.status === 'Sap het' ? 'text-bg-warning' : 'text-bg-success') %>">
                                        <%= ticket.status %>
                                    </span>
                                </td>
                                <td>
                                    <% if (ticket.imageUrl) { %>
                                        <img class="thumb thumb-table img-thumbnail" src="<%= ticket.imageUrl %>" alt="ticket-image">
                                    <% } else { %>
                                        <span class="text-muted">Khong co</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a class="btn btn-sm btn-outline-primary" href="/tickets/<%= ticket.ticketId %>/edit">Sua</a>
                                        <form method="POST" action="/tickets/<%= ticket.ticketId %>/delete" onsubmit="return confirm('Ban chac chan muon xoa?');">
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Xoa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            </div>
        </section>
    </main>

</body>

</html>