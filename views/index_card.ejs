<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quan ly</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">
    <% const totalAmount = (tickets || []).reduce((sum, t) => {
        const price = Number(t.price) || 0
        const quantity = Number(t.quantity) || 0
        return sum + (price * quantity)
    }, 0) %>
    <main class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">Quan ly ve</h1>
            <a class="btn btn-primary btn-sm" href="/tickets/new">+ Them ve</a>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form class="row g-2" method="GET" action="/">
                    <div class="col-md-4">
                        <input class="form-control form-control-sm" type="text" name="keyword" placeholder="Tim theo ten..." value="<%= keyword || '' %>">
                    </div>
                    <div class="col-md-3">
                        <select class="form-control form-control-sm" name="type">
                            <option value="">-- Tat ca loai --</option>
                            <option value="VIP" <%= type === 'VIP' ? 'selected' : '' %>>VIP</option>
                            <option value="Standard" <%= type === 'Standard' ? 'selected' : '' %>>Standard</option>
                            <option value="Economy" <%= type === 'Economy' ? 'selected' : '' %>>Economy</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-outline-primary btn-sm" type="submit">Search</button>
                        <a class="btn btn-outline-secondary btn-sm" href="/">Reset</a>
                    </div>
                    <div class="col-md d-flex align-items-center justify-content-md-end">
                        <span class="small text-muted me-2">Tong tien:</span>
                        <span class="fw-semibold text-primary"><%= totalAmount.toLocaleString('vi-VN') %> VND</span>
                    </div>
                </form>
            </div>
        </div>

        <div class="row g-4">
            <% if (!tickets || tickets.length === 0) { %>
                <div class="col-12">
                    <div class="alert alert-secondary mb-0">Khong co du lieu</div>
                </div>
            <% } %>

            <% (tickets || []).forEach((t) => { %>
                <div class="col-8 col-md-4 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <% if (t.imageUrl) { %>
                            <img src="<%= t.imageUrl %>" alt="<%= t.eventName %>" class="card-img-top" style="height: 180px; object-fit: cover;">
                        <% } else { %>
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                                <span class="text-muted">Khong co anh</span>
                            </div>
                        <% } %>

                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0"><%= t.eventName %></h5>
                                <span class="badge text-bg-<%= t.status === 'Het ve' ? 'danger' : (t.status === 'Sap het' ? 'warning' : 'success') %>"><%= t.status %></span>
                            </div>

                            <p class="text-muted small mb-2">ID: <%= t.ticketId %></p>
                            <p class="mb-1">Loai: <strong><span class="badge text-bg-info"><%= t.type || '-' %></span></strong></p>
                            <p class="mb-1">Gia: <strong><%= Number(t.price || 0).toLocaleString('vi-VN') %> VND</strong></p>
                            <p class="mb-3">So luong: <strong><%= t.quantity %></strong></p>

                            <div class="mt-auto d-flex gap-1 flex-wrap">
                                <a class="btn btn-sm btn-outline-primary" href="/tickets/<%= t.ticketId %>">Chi tiet</a>
                                <a class="btn btn-sm btn-outline-warning" href="/tickets/<%= t.ticketId %>/edit">Sua</a>
                                <button type="button" class="btn btn-sm btn-outline-danger" data-bs-target="#deleteModal" data-ticketid="<%= t.ticketId %>">Xoa</button>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </main>

    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Xoa ve</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Ban chac chan muon xoa ve nay? Hanh dong nay khong the khoi phuc.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huy</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Xoa</button>
                </div>
            </div>
        </div>
    </div>

    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="successToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body" id="toastMessage"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const message = '<%= message %>'
            if (message && message.trim()) {
                document.getElementById('toastMessage').textContent = message
                const toastElement = document.getElementById('successToast')
                const toast = new bootstrap.Toast(toastElement)
                toast.show()
            }

            let ticketIdToDelete = null
            const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'))
            document.querySelectorAll('[data-bs-target="#deleteModal"]').forEach((btn) => {
                btn.addEventListener('click', (e) => {
                    ticketIdToDelete = e.currentTarget.dataset.ticketid
                    deleteModal.show()
                })
            })

            document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
                if (!ticketIdToDelete) return
                const form = document.createElement('form')
                form.method = 'POST'
                form.action = `/tickets/${ticketIdToDelete}/delete`
                document.body.appendChild(form)
                form.submit()
            })
        })
    </script>
</body>

</html>
