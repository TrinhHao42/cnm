<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= mode==='edit' ? 'Sua ve' : 'Them ve' %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">
    <main class="container py-4">
        <div class="card border-0 shadow-sm mx-auto" style="max-width: 600px;">
            <div class="card-body p-4">
                <h1 class="h5 mb-3">
                    <%= mode==='edit' ? 'Sua thong tin ve' : 'Them ve moi' %>
                </h1>
                <% if (errors && errors.length> 0) { %>
                    <div class="alert alert-danger py-2 mb-3">
                        <strong>Lỗi:</strong>
                        <% errors.forEach((e)=> { %>
                            <div><%= e %></div>
                        <% }) %>
                    </div>
                <% } %>
                        <form action="<%= mode === 'edit' ? '/tickets/' + ticket.ticketId : '/tickets' %>" method="POST"
                            enctype="multipart/form-data" class="row g-2">
                            <div class="col-md-6"><label class="form-label">Ma ve</label> <input
                                    class="form-control form-control-sm" type="text" name="ticketId"
                                    value="<%= ticket.ticketId || '' %>" <%=mode==='edit' ? 'readonly' : '' %>></div>
                            <div class="col-md-6"><label class="form-label">Ten su kien</label> <input
                                    class="form-control form-control-sm" type="text" name="eventName"
                                    value="<%= ticket.eventName || '' %>"></div>
                            <div class="col-md-6"><label class="form-label">Gia ve</label> <input
                                    class="form-control form-control-sm" type="number" name="price" min="1"
                                    value="<%= ticket.price || '' %>"></div>
                            <div class="col-md-6"><label class="form-label">So luong</label> <input
                                    class="form-control form-control-sm" type="number" name="quantity" min="0"
                                    value="<%= ticket.quantity || '' %>"></div>
                            <div class="col-md-6"><label class="form-label">Loai ve</label> <select
                                    class="form-control form-control-sm" name="type">
                                    <option value="" <%= !(ticket.typeTicket || ticket.type) ? 'selected' : '' %>>-- Chon loai --</option>
                                    <option value="VIP" <%= (ticket.typeTicket || ticket.type) === 'VIP' ? 'selected' : '' %>>VIP</option>
                                    <option value="Standard" <%= (ticket.typeTicket || ticket.type) === 'Standard' ? 'selected' : '' %>>Standard</option>
                                    <option value="Economy" <%= (ticket.typeTicket || ticket.type) === 'Economy' ? 'selected' : '' %>>Economy</option>
                                </select></div>
                            <div class="col-12"><label class="form-label">Anh ve</label> <input
                                    class="form-control form-control-sm" type="file" name="image" accept="image/*">
                            </div>
                            <% if (ticket.imageUrl) { %>
                                <div class="col-12"><img class="img-thumbnail" src="<%= ticket.imageUrl %>" alt="ticket"
                                        style="max-width: 200px;"></div>
                                <% } %>
                                    <div class="col-12 d-flex gap-2"><button class="btn btn-primary btn-sm"
                                            type="submit">
                                            <%= mode==='edit' ? 'Cap nhat' : 'Them' %>
                                        </button> <a class="btn btn-outline-secondary btn-sm" href="/">Huy</a></div>
                        </form>
            </div>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>