<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quan ly</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">
    <main class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">Quan ly ve</h1> <a class="btn btn-primary btn-sm" href="/tickets/new">+ Them ve</a>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form class="row g-2 mb-3" method="GET" action="/">
                    <div class="col-md-6"><input class="form-control form-control-sm" type="text" name="keyword"
                            placeholder="Tim theo ten..." value="<%= keyword || '' %>"></div>
                    <div class="col-auto"><button class="btn btn-outline-primary btn-sm" type="submit">Search</button> <a
                            class="btn btn-outline-secondary btn-sm" href="/">Reset</a></div>
                </form>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Event</th>
                                        <th>Image</th>
                                        <th>Price</th>
                                        <th>Quantity</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (!tickets || tickets.length===0) { %>
                                        <tr>
                                            <td colspan="7" class="text-center text-muted">Khong co du lieu</td>
                                        </tr>
                                        <% } %>
                                            <% (tickets || []).forEach((t)=> { %><tr>
                                                    <td class="small">
                                                        <%= t.ticketId %>
                                                    </td>
                                                    <td class="small">
                                                        <%= t.eventName %>
                                                    </td>
                                                    <td class="small">
                                                        <% if (t.imageUrl) { %>
                                                            <img src="<%= t.imageUrl %>" alt="<%= t.eventName %>" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: cover;">
                                                        <% } else { %>
                                                            <span class="text-muted">-</span>
                                                        <% } %>
                                                    </td>
                                                    <td class="small">
                                                        <%= Number(t.price || 0).toLocaleString('vi-VN') %>k
                                                    </td>
                                                    <td class="small">
                                                        <%= t.quantity %>
                                                    </td>
                                                    <td class="small"><span
                                                            class="badge text-bg-<%= t.status === 'Het ve' ? 'danger' : (t.status === 'Sap het' ? 'warning' : 'success') %>">
                                                            <%= t.status %>
                                                        </span></td>
                                                    <td class="small">
                                                        <div class="d-flex gap-1"><a
                                                                class="btn btn-xs btn-outline-primary"
                                                                href="/tickets/<%= t.ticketId %>">Chi tiet</a>
                                                            <a class="btn btn-xs btn-outline-warning" href="/tickets/<%= t.ticketId %>/edit">Sua</a>
                                                            <button type="button" class="btn btn-xs btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal" data-ticketid="<%= t.ticketId %>">Xoa</button>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                </tbody>
                            </table>
                        </div>
        </div>
    </main>
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Xóa vé</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Bạn chắc chắn muốn xóa vé này? Hành động này không thể khôi phục.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Xóa</button>
                </div>
            </div>
        </div>
    </div>
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="successToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true" data-message="<%= message || '' %>">
            <div class="toast-header bg-success text-white">
                <strong class="me-auto">✓ Thông báo</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body" id="toastMessage"></div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const toastElement = document.getElementById('successToast')
            const message = toastElement.dataset.message
            if (message) {
                document.getElementById('toastMessage').textContent = message
                const toast = new bootstrap.Toast(toastElement)
                toast.show()
            }
            
            let ticketIdToDelete = null
            const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'))
            document.querySelectorAll('[data-bs-target="#deleteModal"]').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    ticketIdToDelete = e.target.dataset.ticketid
                    deleteModal.show()
                })
            })
            document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
                if (ticketIdToDelete) {
                    const form = document.createElement('form')
                    form.method = 'POST'
                    form.action = `/tickets/${ticketIdToDelete}/delete`
                    document.body.appendChild(form)
                    form.submit()
                }
            })
        })
    </script>
</body>

</html>